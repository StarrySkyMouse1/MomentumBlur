<Page x:Class="mmod_record.Views.Pages.RecordComposePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:mmod_record.Views.Controls"
      xmlns:models="clr-namespace:mmod_record.Models"
      mc:Ignorable="d"
      Title="合成"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <StackPanel Margin="0,0,0,24">
        <Border Margin="0,16,0,0"
                Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="28">
            <StackPanel>
                <ui:TextBlock Text="合成"
                              FontTypography="Title"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              Margin="0,0,0,8"/>
                <ui:TextBlock Text="添加或拖入视频文件，勾选后批量合成；可在设置中配置并行路数。"
                              FontTypography="Body"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              TextWrapping="Wrap"
                              Margin="0,0,0,8"/>

                <controls:SettingSection Title="CPU使用率"
                                         Description="系统整体 CPU 占用，约每秒刷新。"
                                         Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar Grid.Column="0"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding Record.CpuUsagePercent}"
                                     Margin="0,0,12,0"/>
                        <ui:TextBlock Grid.Column="1"
                                      Text="{Binding Record.CpuUsageText}"
                                      FontTypography="BodyStrong"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      VerticalAlignment="Center"
                                      MinWidth="40"
                                      TextAlignment="Right"/>
                    </Grid>
                </controls:SettingSection>

                <controls:SettingsGroup Title="当前配置"
                                        Description="修改设置后会自动刷新。">
                    <ui:TextBlock Text="{Binding Record.PipelineConfigSummaryText}"
                                  TextWrapping="Wrap"
                                  FontTypography="Body"
                                  FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                                  LineHeight="22"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </controls:SettingsGroup>

                <controls:SettingsGroup Title="批量队列"
                                        Description="拖入视频文件或点击添加；勾选需要合成的文件。">
                    <StackPanel>
                        <ui:TextBlock Text="{Binding Record.BatchQueueSummaryText}"
                                       FontTypography="BodyStrong"
                                       Margin="0,0,0,10"/>
                        <ui:Button Content="添加文件…"
                                   HorizontalAlignment="Left"
                                   Command="{Binding Record.AddVideoFilesCommand}"
                                   IsEnabled="{Binding Record.IsQueueEditEnabled}"
                                   Margin="0,0,0,10"/>
                        <Border x:Name="DropZone"
                                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinHeight="360"
                                Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid>
                                <ui:TextBlock Text="将视频文件拖放到此处"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontTypography="Caption"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               IsHitTestVisible="False"/>
                                <ListBox ItemsSource="{Binding Record.BatchItems}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         IsEnabled="{Binding Record.IsQueueEditEnabled}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:BatchVideoItem}">
                                        <Grid Margin="4,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                            <StackPanel Grid.Column="1">
                                                <ui:TextBlock Text="{Binding FileName}"
                                                               FontTypography="Body"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding FullPath}"/>
                                                <ui:TextBlock Text="{Binding StatusText}"
                                                               FontTypography="Caption"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                <ProgressBar Height="4"
                                                             Margin="0,6,0,0"
                                                             Minimum="0"
                                                             Maximum="100"
                                                             Value="{Binding ProgressPercent}">
                                                    <ProgressBar.Style>
                                                        <Style TargetType="ProgressBar">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:BatchItemStatus.Running}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ProgressBar.Style>
                                                </ProgressBar>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </controls:SettingsGroup>

                <controls:SettingsGroup Title="操作与状态">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ui:Button Content="开始批量合成"
                                       Appearance="Primary"
                                       Command="{Binding Record.StartSynthesisCommand}"
                                       IsEnabled="{Binding Record.IsStartEnabled}"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="取消"
                                       Command="{Binding Record.CancelSynthesisCommand}"
                                       IsEnabled="{Binding Record.IsCancelEnabled}"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="打开成片目录"
                                       Command="{Binding Record.OpenOutputFolderCommand}"/>
                        </StackPanel>

                        <ui:TextBlock Text="{Binding Record.PipelinePhaseText}"
                                       FontTypography="BodyStrong"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                        <ui:TextBlock Text="{Binding Record.PipelineMetricsText}"
                                       TextWrapping="Wrap"
                                       FontTypography="Caption"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0"
                                         Height="8"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="{Binding Record.SynthesisProgressPercent}"
                                         Margin="0,0,12,0"/>
                            <ui:TextBlock Grid.Column="1"
                                          Text="{Binding Record.SynthesisProgressText}"
                                          FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center"
                                          MinWidth="200"
                                          TextAlignment="Right"/>
                        </Grid>
                        <ui:TextBlock Text="{Binding Record.PipelineMessageText}"
                                       TextWrapping="Wrap"
                                       FontTypography="Body"
                                       Foreground="{Binding Record.PipelineMessageBrush}"/>
                    </StackPanel>
                </controls:SettingsGroup>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
