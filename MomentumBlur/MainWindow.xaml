<ui:FluentWindow x:Class="mmod_record.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:pages="clr-namespace:mmod_record.Views.Pages"
                 xmlns:models="clr-namespace:mmod_record.Models"
                 mc:Ignorable="d"
                 Title="{x:Static models:ProjectConstants.ApplicationDisplayName}"
                 Height="720"
                 Width="900"
                 MinHeight="600"
                 MinWidth="700"
                 ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                 ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Default"
                 WindowStartupLocation="CenterScreen">
    <Grid>
        <ui:NavigationView x:Name="RootNavigation"
                           Padding="32,0,32,0"
                           FrameMargin="0"
                           TitleBar="{Binding ElementName=TitleBar}"
                           IsBackButtonVisible="Collapsed"
                           IsFooterSeparatorVisible="False"
                           IsPaneToggleVisible="True"
                           IsTopSeparatorVisible="False"
                           OpenPaneLength="220"
                           PaneDisplayMode="Left"
                           Transition="FadeInWithSlide"
                           TransitionDuration="200">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="合成"
                                       Icon="{ui:SymbolIcon Video24}"
                                       TargetPageType="{x:Type pages:RecordComposePage}" />
                <ui:NavigationViewItem Content="设置"
                                       Icon="{ui:SymbolIcon Settings24}"
                                       TargetPageType="{x:Type pages:SettingsPage}" />
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>

        <ui:TitleBar x:Name="TitleBar"
                     Title="{x:Static models:ProjectConstants.ApplicationDisplayName}"
                     CloseWindowByDoubleClickOnIcon="True" />
    </Grid>
</ui:FluentWindow>
